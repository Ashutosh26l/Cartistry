<%- include("partials/header", { title: "Products" }) %>

<style>
  .catalog-shell {
    display: grid;
    gap: 24px;
  }
  .filter-chip-active {
    border-color: #2563eb;
    background-color: #dbeafe;
    color: #1d4ed8;
  }
  .filter-chip {
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease, box-shadow 160ms ease;
  }
  html.dark .filter-chip {
    border-color: #2b3a55 !important;
    background-color: #0b1220 !important;
    color: #dbe7ff !important;
  }
  html.dark .filter-chip-active {
    border-color: #7dd3fc !important;
    background-color: rgba(8, 145, 178, 0.28) !important;
    color: #e0f7ff !important;
    box-shadow: inset 0 0 0 1px rgba(125, 211, 252, 0.24);
  }
  .price-range {
    --min-position: 0%;
    --max-position: 100%;
    --thumb-safe-inset: 11px;
    position: relative;
  }
  .price-range-track {
    position: absolute;
    left: var(--thumb-safe-inset);
    right: var(--thumb-safe-inset);
    top: 50%;
    height: 6px;
    transform: translateY(-50%);
    border-radius: 999px;
    background: #dbeafe;
  }
  .price-range-track::after {
    content: "";
    position: absolute;
    left: var(--min-position);
    right: calc(100% - var(--max-position));
    top: 0;
    bottom: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, #06b6d4, #2563eb);
  }
  .price-range-input {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--thumb-safe-inset);
    right: var(--thumb-safe-inset);
    width: auto;
    height: 44px;
    margin: 0;
    appearance: none;
    background: transparent;
    border: 0;
    pointer-events: none;
  }
  .price-range-input::-webkit-slider-runnable-track {
    height: 6px;
    background: transparent;
    border: 0;
  }
  [data-price-min-range] {
    z-index: 3;
  }
  [data-price-max-range] {
    z-index: 3;
  }
  .price-range-input::-webkit-slider-thumb {
    width: 22px;
    height: 22px;
    appearance: none;
    border: 4px solid #ffffff;
    border-radius: 999px;
    background: #0891b2;
    box-shadow: 0 6px 16px rgba(15, 23, 42, 0.22);
    cursor: grab;
    pointer-events: auto;
  }
  .price-range-input::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border: 4px solid #ffffff;
    border-radius: 999px;
    background: #0891b2;
    box-shadow: 0 6px 16px rgba(15, 23, 42, 0.22);
    cursor: grab;
    pointer-events: auto;
  }
  .price-range-input::-moz-range-track {
    background: transparent;
  }
  :root.dark .price-range-track,
  html.dark .price-range-track,
  body.dark .price-range-track {
    background: linear-gradient(180deg, #0a1730, #0f2240);
    border: 1px solid rgba(125, 211, 252, 0.24);
    box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.15);
  }
  :root.dark .price-range-card,
  html.dark .price-range-card,
  body.dark .price-range-card {
    border-color: rgba(125, 211, 252, 0.28) !important;
    background: radial-gradient(circle at top left, rgba(34, 211, 238, 0.12), rgba(15, 23, 42, 0.45) 52%), #0f223b !important;
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.08);
  }
  :root.dark [data-min-price-label],
  :root.dark [data-max-price-label],
  html.dark [data-min-price-label],
  html.dark [data-max-price-label],
  body.dark [data-min-price-label],
  body.dark [data-max-price-label] {
    color: #d6eeff !important;
    letter-spacing: 0.01em;
    text-shadow: 0 0 12px rgba(56, 189, 248, 0.16);
  }
  :root.dark .price-range-input::-webkit-slider-thumb,
  html.dark .price-range-input::-webkit-slider-thumb,
  body.dark .price-range-input::-webkit-slider-thumb {
    border-color: #082034;
    background: radial-gradient(circle at 35% 30%, #a5f3fc 0%, #67e8f9 58%, #22d3ee 100%);
    box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.2), 0 10px 22px rgba(8, 145, 178, 0.35);
  }
  :root.dark .price-range-input::-moz-range-thumb,
  html.dark .price-range-input::-moz-range-thumb,
  body.dark .price-range-input::-moz-range-thumb {
    border-color: #082034;
    background: radial-gradient(circle at 35% 30%, #a5f3fc 0%, #67e8f9 58%, #22d3ee 100%);
    box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.2), 0 10px 22px rgba(8, 145, 178, 0.35);
  }
  :root.dark .price-range-input,
  html.dark .price-range-input,
  body.dark .price-range-input {
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
  }
  :root.dark [data-price-min-range]::-webkit-slider-thumb,
  html.dark [data-price-min-range]::-webkit-slider-thumb,
  body.dark [data-price-min-range]::-webkit-slider-thumb {
    border-color: #f8fafc;
    background: radial-gradient(circle at 35% 30%, #fde68a 0%, #f59e0b 58%, #d97706 100%);
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.25), 0 10px 22px rgba(180, 83, 9, 0.4);
  }
  :root.dark [data-price-min-range]::-moz-range-thumb,
  html.dark [data-price-min-range]::-moz-range-thumb,
  body.dark [data-price-min-range]::-moz-range-thumb {
    border-color: #f8fafc;
    background: radial-gradient(circle at 35% 30%, #fde68a 0%, #f59e0b 58%, #d97706 100%);
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.25), 0 10px 22px rgba(180, 83, 9, 0.4);
  }
  :root.dark .price-range-track::after,
  html.dark .price-range-track::after,
  body.dark .price-range-track::after {
    background: linear-gradient(90deg, #22d3ee, #38bdf8 40%, #60a5fa 100%);
    box-shadow: 0 0 14px rgba(56, 189, 248, 0.4);
  }
  @media (prefers-color-scheme: dark) {
    :root:not(.light) .price-range-track {
      background: linear-gradient(180deg, #0a1730, #0f2240);
      border: 1px solid rgba(125, 211, 252, 0.24);
      box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.15);
    }
    :root:not(.light) .price-range-card {
      border-color: rgba(125, 211, 252, 0.28) !important;
      background: radial-gradient(circle at top left, rgba(34, 211, 238, 0.12), rgba(15, 23, 42, 0.45) 52%), #0f223b !important;
      box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.08);
    }
    :root:not(.light) .price-range-track::after {
      background: linear-gradient(90deg, #22d3ee, #38bdf8 40%, #60a5fa 100%);
      box-shadow: 0 0 14px rgba(56, 189, 248, 0.4);
    }
  }
  .product-image {
    transition: transform 450ms ease;
    transform-origin: center;
    will-change: transform;
  }
  .product-image-wrap:hover .product-image {
    transform: scale(1.08);
  }
  @media (min-width: 1024px) {
    .catalog-shell {
      grid-template-columns: 320px minmax(0, 1fr);
      align-items: start;
    }
  }
</style>

<%
const isRetailer = currentUser && (currentUser.role === "retailer" || currentUser.role === "admin");
const isBuyer = currentUser && currentUser.role === "buyer";
const filters = selectedFilters || {};
const pager = pagination || { page: 1, totalPages: 1, hasPrev: false, hasNext: false, prevPage: 1, nextPage: 1, totalItems: 0 };
const bounds = priceBounds || { min: 0, max: 1000 };
const priceMinLimit = Math.max(0, Math.floor(Number(bounds.min) || 0));
const rawPriceMaxLimit = Math.ceil(Number(bounds.max) || 1000);
const priceMaxLimit = Math.max(priceMinLimit + 1, rawPriceMaxLimit);
const selectedMinPrice = filters.minPrice ? Math.min(priceMaxLimit, Math.max(priceMinLimit, Number(filters.minPrice))) : priceMinLimit;
const selectedMaxPrice = filters.maxPrice ? Math.min(priceMaxLimit, Math.max(selectedMinPrice, Number(filters.maxPrice))) : priceMaxLimit;
const queryForLink = (targetPage) => {
  const params = new URLSearchParams();
  if (filters.q) params.set("q", filters.q);
  if (filters.category) params.set("category", filters.category);
  if (filters.brand) params.set("brand", filters.brand);
  if (filters.minPrice) params.set("minPrice", filters.minPrice);
  if (filters.maxPrice) params.set("maxPrice", filters.maxPrice);
  if (filters.availability) params.set("availability", filters.availability);
  if (filters.sort) params.set("sort", filters.sort);
  if (filters.limit) params.set("limit", String(filters.limit));
  if (targetPage && targetPage > 1) params.set("page", String(targetPage));
  const query = params.toString();
  return query ? `/products/allProducts?${query}` : "/products/allProducts";
};
const currentQueryPath = queryForLink(pager.page || 1);
%>

<section class="min-h-screen py-8">
  <div class="max-w-6xl mx-auto">
    <%- include("partials/flash") %>
    <div class="mb-8 flex items-center justify-between gap-4">
      <h1 class="text-3xl font-bold text-gray-900 text-center"><%= isRetailer ? "My Products" : "Shop Products" %></h1>
      <% if (isRetailer) { %>
      <a href="/products/new" class="rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-5 py-2.5">Add Product</a>
      <% } %>
    </div>

    <div class="mb-4 grid grid-cols-2 gap-3 lg:hidden">
      <button id="mobileFilterToggle" type="button" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm">
        <span>Filter</span>
        <span id="mobileFilterToggleIcon" class="text-slate-500">+</span>
      </button>
      <button id="mobileSortToggle" type="button" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm">
        <span>Sort</span>
        <span id="mobileSortToggleIcon" class="text-slate-500">+</span>
      </button>
    </div>

    <div class="catalog-shell">
      <aside id="mobileFilterPanel" class="hidden lg:block lg:sticky lg:top-24">
        <form action="/products/allProducts" method="get" class="rounded-[28px] border border-slate-200 bg-white shadow-sm overflow-hidden">
          <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200">
            <div>
              <p class="text-lg font-semibold text-slate-900">Filter</p>
              <p class="text-xs text-slate-500">Refine your catalog view</p>
            </div>
            <a href="/products/allProducts" class="text-sm font-medium text-cyan-600 hover:text-cyan-700">Clear</a>
          </div>

          <input type="hidden" name="q" value="<%= filters.q || '' %>" />

          <div class="filter-group border-b border-slate-100">
            <button type="button" class="filter-group-toggle w-full flex items-center justify-between px-5 py-4 text-left">
              <span class="font-semibold text-slate-900">Brand</span>
              <span class="text-slate-400 text-xl leading-none">+</span>
            </button>
            <div class="filter-group-body px-5 pb-5">
              <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 mb-4">
                <select id="brandPreviewSelect" name="brand" class="w-full bg-transparent text-sm text-slate-700 focus:outline-none">
                  <option value="">All brands</option>
                  <% (brands || []).forEach(function(option) { %>
                    <option value="<%= option %>" <%= filters.brand === option ? 'selected' : '' %>><%= option %></option>
                  <% }); %>
                </select>
              </div>
              <div class="space-y-2 max-h-56 overflow-auto pr-1">
                <% (brands || []).slice(0, 8).forEach(function(option) { %>
                  <label class="flex items-center justify-between rounded-xl px-3 py-2 border <%= filters.brand === option ? 'border-cyan-400 bg-cyan-50 text-cyan-700' : 'border-transparent hover:border-slate-200 text-slate-700' %>">
                    <span class="flex items-center gap-3">
                      <input type="radio" name="brandOption" value="<%= option %>" class="h-4 w-4 accent-cyan-600" <%= filters.brand === option ? 'checked' : '' %> />
                      <span class="text-sm font-medium"><%= option %></span>
                    </span>
                    <span class="text-xs text-slate-400"><%= option.length %></span>
                  </label>
                <% }); %>
              </div>
            </div>
          </div>

          <div class="filter-group border-b border-slate-100">
            <button type="button" class="filter-group-toggle w-full flex items-center justify-between px-5 py-4 text-left">
              <span class="font-semibold text-slate-900">Category</span>
              <span class="text-slate-400 text-xl leading-none">+</span>
            </button>
            <div class="filter-group-body px-5 pb-5 hidden">
              <div class="flex flex-wrap gap-2">
                <label class="cursor-pointer">
                  <input type="radio" name="category" value="" class="sr-only" <%= !filters.category ? 'checked' : '' %> />
                  <span class="filter-chip block rounded-full border px-4 py-2 text-sm <%= !filters.category ? 'filter-chip-active' : 'border-slate-200 text-slate-700' %>">All</span>
                </label>
                <% (categories || []).forEach(function(option) { %>
                  <label class="cursor-pointer">
                    <input type="radio" name="category" value="<%= option %>" class="sr-only" <%= filters.category === option ? 'checked' : '' %> />
                    <span class="filter-chip block rounded-full border px-4 py-2 text-sm <%= filters.category === option ? 'filter-chip-active' : 'border-slate-200 text-slate-700' %>"><%= option %></span>
                  </label>
                <% }); %>
              </div>
            </div>
          </div>

          <div class="filter-group border-b border-slate-100">
            <button type="button" class="filter-group-toggle w-full flex items-center justify-between px-5 py-4 text-left">
              <span class="font-semibold text-slate-900">Price</span>
              <span class="text-slate-400 text-xl leading-none">+</span>
            </button>
            <div class="filter-group-body px-5 pb-5 hidden">
              <div class="price-range-card rounded-2xl border border-cyan-100 bg-cyan-50/60 px-4 py-4 mb-4">
                <div class="flex items-center justify-between text-xs font-semibold text-slate-500">
                  <span data-min-price-label>&#8377; <%= selectedMinPrice %></span>
                  <span data-max-price-label>&#8377; <%= selectedMaxPrice %></span>
                </div>
                <div
                  class="price-range mt-4 h-11"
                  data-price-range
                  data-min="<%= priceMinLimit %>"
                  data-max="<%= priceMaxLimit %>"
                >
                  <div class="price-range-track"></div>
                  <input
                    type="range"
                    min="<%= priceMinLimit %>"
                    max="<%= priceMaxLimit %>"
                    step="1"
                    value="<%= selectedMinPrice %>"
                    class="price-range-input"
                    data-price-min-range
                    aria-label="Minimum price"
                  />
                  <input
                    type="range"
                    min="<%= priceMinLimit %>"
                    max="<%= priceMaxLimit %>"
                    step="1"
                    value="<%= selectedMaxPrice %>"
                    class="price-range-input"
                    data-price-max-range
                    aria-label="Maximum price"
                  />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <input type="number" min="<%= priceMinLimit %>" max="<%= priceMaxLimit %>" name="minPrice" value="<%= selectedMinPrice %>" placeholder="Min" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:outline-none focus:border-cyan-500 focus:bg-white" data-price-min-input />
                <input type="number" min="<%= priceMinLimit %>" max="<%= priceMaxLimit %>" name="maxPrice" value="<%= selectedMaxPrice %>" placeholder="Max" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:outline-none focus:border-cyan-500 focus:bg-white" data-price-max-input />
              </div>
            </div>
          </div>

          <div class="filter-group border-b border-slate-100">
            <button type="button" class="filter-group-toggle w-full flex items-center justify-between px-5 py-4 text-left">
              <span class="font-semibold text-slate-900">Availability</span>
              <span class="text-slate-400 text-xl leading-none">+</span>
            </button>
            <div class="filter-group-body px-5 pb-5 hidden">
              <div class="grid grid-cols-1 gap-2">
                <label class="flex items-center gap-3 rounded-2xl border px-4 py-3 <%= !filters.availability ? 'border-cyan-400 bg-cyan-50 text-cyan-700' : 'border-slate-200 text-slate-700' %>">
                  <input type="radio" name="availability" value="" class="h-4 w-4 accent-cyan-600" <%= !filters.availability ? 'checked' : '' %> />
                  <span class="text-sm font-medium">All products</span>
                </label>
                <label class="flex items-center gap-3 rounded-2xl border px-4 py-3 <%= filters.availability === 'true' ? 'border-cyan-400 bg-cyan-50 text-cyan-700' : 'border-slate-200 text-slate-700' %>">
                  <input type="radio" name="availability" value="true" class="h-4 w-4 accent-cyan-600" <%= filters.availability === 'true' ? 'checked' : '' %> />
                  <span class="text-sm font-medium">In stock</span>
                </label>
                <label class="flex items-center gap-3 rounded-2xl border px-4 py-3 <%= filters.availability === 'false' ? 'border-cyan-400 bg-cyan-50 text-cyan-700' : 'border-slate-200 text-slate-700' %>">
                  <input type="radio" name="availability" value="false" class="h-4 w-4 accent-cyan-600" <%= filters.availability === 'false' ? 'checked' : '' %> />
                  <span class="text-sm font-medium">Out of stock</span>
                </label>
              </div>
            </div>
          </div>

          <div class="px-5 py-5 space-y-3">
            <button type="submit" class="w-full rounded-2xl bg-slate-900 hover:bg-slate-800 text-white font-semibold py-3">Apply Filters</button>
            <a href="/products/allProducts" class="block w-full rounded-2xl border border-slate-200 hover:border-slate-300 text-center text-slate-700 font-medium py-3">Reset</a>
          </div>
        </form>
      </aside>

      <div>
        <form id="mobileSortPanel" action="/products/allProducts" method="get" class="hidden lg:block mb-5 rounded-[28px] border border-slate-200 bg-white px-5 py-4 shadow-sm">
          <input type="hidden" name="q" value="<%= filters.q || '' %>" />
          <input type="hidden" name="category" value="<%= filters.category || '' %>" />
          <input type="hidden" name="brand" value="<%= filters.brand || '' %>" />
          <input type="hidden" name="minPrice" value="<%= filters.minPrice || '' %>" />
          <input type="hidden" name="maxPrice" value="<%= filters.maxPrice || '' %>" />
          <input type="hidden" name="availability" value="<%= filters.availability || '' %>" />
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Results</p>
              <p class="mt-1 text-slate-700">Showing <span class="font-semibold text-slate-900"><%= allProducts.length %></span> of <span class="font-semibold text-slate-900"><%= pager.totalItems || 0 %></span> products</p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
              <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                <span class="text-sm font-medium text-slate-500">Sort</span>
                <select name="sort" class="bg-transparent text-sm font-semibold text-slate-800 focus:outline-none">
                  <option value="relevance" <%= filters.sort === 'relevance' ? 'selected' : '' %>>Relevance</option>
                  <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
                  <option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
                  <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
                  <option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>Name: A to Z</option>
                  <option value="name_desc" <%= filters.sort === 'name_desc' ? 'selected' : '' %>>Name: Z to A</option>
                </select>
              </label>
              <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                <span class="text-sm font-medium text-slate-500">Show</span>
                <select name="limit" class="bg-transparent text-sm font-semibold text-slate-800 focus:outline-none">
                  <option value="9" <%= String(filters.limit) === '9' ? 'selected' : '' %>>9</option>
                  <option value="12" <%= String(filters.limit) === '12' ? 'selected' : '' %>>12</option>
                  <option value="24" <%= String(filters.limit) === '24' ? 'selected' : '' %>>24</option>
                  <option value="48" <%= String(filters.limit) === '48' ? 'selected' : '' %>>48</option>
                </select>
              </label>
              <button type="submit" class="rounded-2xl bg-cyan-500 hover:bg-cyan-600 text-slate-950 font-semibold px-5 py-3">Update</button>
            </div>
          </div>
        </form>

        <div class="grid grid-cols-2 md:grid-cols-2 xl:grid-cols-3 gap-3 sm:gap-6">
      <% if (allProducts && allProducts.length > 0) { %>
      <% allProducts.forEach(function(item) { %>
      <div class="relative bg-white rounded-lg sm:rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all" data-animate-card>
        <% if (isBuyer) { %>
        <form action="/products/<%= item._id %>/wishlist" method="POST" class="absolute top-2 sm:top-3 left-2 sm:left-3 z-10">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="redirectTo" value="<%= currentQueryPath %>" />
          <button
            type="submit"
            aria-label="<%= item.isWishlisted ? 'Remove from wishlist' : 'Add to wishlist' %>"
            class="h-8 w-8 sm:h-10 sm:w-10 rounded-full border border-slate-200 bg-white text-lg sm:text-2xl leading-none shadow-md hover:shadow-lg hover:scale-105 transition-all flex items-center justify-center <%= item.isWishlisted ? 'text-rose-600 ring-2 ring-rose-200' : 'text-slate-700' %>"
          >
            <%- item.isWishlisted ? '&#9829;' : '&#9825;' %>
          </button>
        </form>
        <% } %>
        <a href="/products/<%= item._id %>" class="block">
          <div class="product-image-wrap relative h-32 sm:h-48 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center overflow-hidden">
            <img src="<%= item.primaryImage %>" alt="<%= item.name %>" class="product-image w-full h-full object-cover" />
            <span class="absolute top-2 sm:top-3 right-2 sm:right-3 <%= item.isAvailable ? 'bg-green-500' : 'bg-red-500' %> text-white px-2.5 sm:px-3 py-0.5 sm:py-1 rounded-full text-[11px] sm:text-sm font-medium">
              <%= item.stockLabel || (item.isAvailable ? 'In Stock' : 'Out of Stock') %>
            </span>
          </div>

          <div class="p-3 sm:p-5 space-y-2 sm:space-y-4">
            <div>
              <h3 class="text-base sm:text-xl font-bold text-gray-900 leading-tight"><%= item.name %></h3>
              <p class="hidden sm:block text-gray-500 mt-1">Warranty: <%= item.warranty %> years</p>
              <p class="text-xs sm:text-base text-gray-500 mt-1">Category: <%= item.category || 'General' %><span class="hidden sm:inline"> &bull; Brand: <%= item.brand || 'Unbranded' %></span></p>
              <p class="text-xs sm:text-sm mt-1 <%= item.isAvailable ? 'text-emerald-700' : 'text-rose-700' %>">Stock: <%= typeof item.stockQuantity === "number" ? item.stockQuantity : 0 %></p>
              <p class="hidden sm:block text-sm mt-1 text-slate-500"><%= item.deliveryEta || '' %></p>
            </div>

            <div class="flex justify-between items-center">
              <p class="text-lg sm:text-2xl font-bold text-gray-900">&#8377; <%= item.price %></p>
              <div class="flex items-center gap-1"><span class="text-[13px] sm:text-base text-yellow-400">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
            </div>

            <span class="block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white text-sm sm:text-base font-medium py-2 sm:py-3 rounded-lg transition-colors">View Details</span>
          </div>
        </a>
      </div>
      <% }); %>
      <% } else { %>
      <div class="col-span-full text-center py-12">
        <p class="text-gray-500 text-xl">No products available with current filters.</p>
      </div>
      <% } %>
        </div>

        <div class="mt-8 flex items-center justify-center gap-2">
          <a href="<%= queryForLink(pager.prevPage) %>" class="px-4 py-2 rounded-lg border border-slate-300 text-slate-700 <%= pager.hasPrev ? 'hover:border-slate-500' : 'opacity-40 pointer-events-none' %>">Previous</a>
          <span class="px-4 py-2 text-sm text-slate-600">Page <%= pager.page %> of <%= pager.totalPages %></span>
          <a href="<%= queryForLink(pager.nextPage) %>" class="px-4 py-2 rounded-lg border border-slate-300 text-slate-700 <%= pager.hasNext ? 'hover:border-slate-500' : 'opacity-40 pointer-events-none' %>">Next</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const groups = document.querySelectorAll(".filter-group");
    const brandPreviewSelect = document.getElementById("brandPreviewSelect");
    const brandInputs = document.querySelectorAll('input[type="radio"][name="brandOption"]');
    const categoryInputs = document.querySelectorAll('input[type="radio"][name="category"]');
    const priceRange = document.querySelector("[data-price-range]");
    const mobileFilterToggle = document.getElementById("mobileFilterToggle");
    const mobileFilterToggleIcon = document.getElementById("mobileFilterToggleIcon");
    const mobileSortToggle = document.getElementById("mobileSortToggle");
    const mobileSortToggleIcon = document.getElementById("mobileSortToggleIcon");
    const mobileFilterPanel = document.getElementById("mobileFilterPanel");
    const mobileSortPanel = document.getElementById("mobileSortPanel");

    const setMobilePanelState = (panel, icon, shouldOpen) => {
      if (!panel || !icon) return;
      panel.classList.toggle("hidden", !shouldOpen);
      icon.textContent = shouldOpen ? "-" : "+";
    };

    if (mobileFilterToggle && mobileFilterPanel) {
      mobileFilterToggle.addEventListener("click", () => {
        const nextOpen = mobileFilterPanel.classList.contains("hidden");
        setMobilePanelState(mobileFilterPanel, mobileFilterToggleIcon, nextOpen);
        setMobilePanelState(mobileSortPanel, mobileSortToggleIcon, false);
      });
    }

    if (mobileSortToggle && mobileSortPanel) {
      mobileSortToggle.addEventListener("click", () => {
        const nextOpen = mobileSortPanel.classList.contains("hidden");
        setMobilePanelState(mobileSortPanel, mobileSortToggleIcon, nextOpen);
        setMobilePanelState(mobileFilterPanel, mobileFilterToggleIcon, false);
      });
    }

    groups.forEach((group, index) => {
      const toggle = group.querySelector(".filter-group-toggle");
      const body = group.querySelector(".filter-group-body");
      const icon = toggle ? toggle.querySelector("span:last-child") : null;
      if (!toggle || !body) return;

      const hasCheckedOption = Boolean(body.querySelector('input[type="radio"]:checked:not([value=""])'));
      const hasSelectedBrand = Boolean(body.querySelector('select[name="brand"] option:checked:not([value=""])'));
      const hasChangedMinPrice = Boolean(body.querySelector("[data-price-min-input]")) && document.querySelector("[data-price-min-input]")?.value !== priceRange?.dataset.min;
      const hasChangedMaxPrice = Boolean(body.querySelector("[data-price-max-input]")) && document.querySelector("[data-price-max-input]")?.value !== priceRange?.dataset.max;
      const hasActiveInput = hasCheckedOption || hasSelectedBrand || hasChangedMinPrice || hasChangedMaxPrice;
      const isOpenByDefault = hasActiveInput;
      body.classList.toggle("hidden", !isOpenByDefault);
      if (icon) icon.textContent = isOpenByDefault ? "-" : "+";

      toggle.addEventListener("click", () => {
        const shouldOpen = body.classList.contains("hidden");
        body.classList.toggle("hidden", !shouldOpen);
        if (icon) icon.textContent = shouldOpen ? "-" : "+";
      });
    });

    const syncCategoryChips = () => {
      categoryInputs.forEach((input) => {
        const chip = input.nextElementSibling;
        if (!chip) return;
        const isActive = input.checked;
        chip.classList.toggle("filter-chip-active", isActive);
        chip.classList.toggle("border-slate-200", !isActive);
        chip.classList.toggle("text-slate-700", !isActive);
      });
    };

    categoryInputs.forEach((input) => {
      input.addEventListener("change", syncCategoryChips);
    });
    syncCategoryChips();

    if (brandPreviewSelect && brandInputs.length > 0) {
      brandPreviewSelect.addEventListener("change", () => {
        const selectedValue = brandPreviewSelect.value;
        brandInputs.forEach((input) => {
          input.checked = input.value === selectedValue;
        });
      });

      brandInputs.forEach((input) => {
        input.addEventListener("change", () => {
          if (!input.checked) return;
          brandPreviewSelect.value = input.value;
        });
      });
    }

    if (priceRange) {
      const minRange = priceRange.querySelector("[data-price-min-range]");
      const maxRange = priceRange.querySelector("[data-price-max-range]");
      const minInput = document.querySelector("[data-price-min-input]");
      const maxInput = document.querySelector("[data-price-max-input]");
      const minLabel = document.querySelector("[data-min-price-label]");
      const maxLabel = document.querySelector("[data-max-price-label]");
      const lowerLimit = Number(priceRange.dataset.min || 0);
      const upperLimit = Number(priceRange.dataset.max || 1000);
      const priceFormatter = new Intl.NumberFormat("en-IN", { maximumFractionDigits: 0 });

      const clamp = (value) => Math.min(upperLimit, Math.max(lowerLimit, Number(value) || 0));
      const bringThumbToFront = (thumb) => {
        if (!minRange || !maxRange) return;
        if (thumb === "min") {
          minRange.style.zIndex = "5";
          maxRange.style.zIndex = "4";
        } else {
          maxRange.style.zIndex = "5";
          minRange.style.zIndex = "4";
        }
      };
      const updatePriceRange = (source) => {
        if (!minRange || !maxRange || !minInput || !maxInput) return;
        let minValue = clamp(source === "minInput" ? minInput.value : minRange.value);
        let maxValue = clamp(source === "maxInput" ? maxInput.value : maxRange.value);

        if (minValue > maxValue) {
          if (source === "minRange" || source === "minInput") {
            minValue = maxValue;
          } else {
            maxValue = minValue;
          }
        }

        minRange.value = String(minValue);
        maxRange.value = String(maxValue);
        minInput.value = String(minValue);
        maxInput.value = String(maxValue);

        const span = Math.max(1, upperLimit - lowerLimit);
        priceRange.style.setProperty("--min-position", `${((minValue - lowerLimit) / span) * 100}%`);
        priceRange.style.setProperty("--max-position", `${((maxValue - lowerLimit) / span) * 100}%`);
        if (minLabel) minLabel.textContent = `\u20b9 ${priceFormatter.format(minValue)}`;
        if (maxLabel) maxLabel.textContent = `\u20b9 ${priceFormatter.format(maxValue)}`;

        // When thumbs overlap/come close, keep the actively edited thumb on top.
        if (source === "minRange" || source === "minInput") {
          bringThumbToFront("min");
        } else if (source === "maxRange" || source === "maxInput") {
          bringThumbToFront("max");
        }
      };

      minRange?.addEventListener("pointerdown", () => bringThumbToFront("min"));
      maxRange?.addEventListener("pointerdown", () => bringThumbToFront("max"));
      minRange?.addEventListener("mousedown", () => bringThumbToFront("min"));
      maxRange?.addEventListener("mousedown", () => bringThumbToFront("max"));
      minRange?.addEventListener("touchstart", () => bringThumbToFront("min"), { passive: true });
      maxRange?.addEventListener("touchstart", () => bringThumbToFront("max"), { passive: true });
      minRange?.addEventListener("input", () => updatePriceRange("minRange"));
      maxRange?.addEventListener("input", () => updatePriceRange("maxRange"));
      minInput?.addEventListener("input", () => updatePriceRange("minInput"));
      maxInput?.addEventListener("input", () => updatePriceRange("maxInput"));
      bringThumbToFront("max");
      updatePriceRange("init");
    }

  })();
</script>

<%- include("partials/footer") %>

