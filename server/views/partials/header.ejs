<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title><%= typeof title !== 'undefined' ? title : 'Ecommerce' %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script>
      (function () {
        const storageKey = "theme";
        const root = document.documentElement;
        const savedTheme = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = savedTheme ? savedTheme === "dark" : prefersDark;
        root.classList.toggle("dark", isDark);
        root.style.colorScheme = isDark ? "dark" : "light";
      })();
    </script>
    <script defer src="/js/theme.js"></script>
    <script defer src="/js/search.js"></script>
    <script defer src="/js/bootstrap-validation.js"></script>
    <script defer src="/vendor/gsap.min.js"></script>
    <script defer src="/js/popup-ui.js"></script>
    <script defer src="/js/animations.js"></script>
    <style>
      :root {
        --dm-bg: #020617;
        --dm-surface: #0b1220;
        --dm-surface-2: #0f172a;
        --dm-surface-3: #111827;
        --dm-text-strong: #f8fafc;
        --dm-text: #dbe7ff;
        --dm-text-muted: #9fb0cc;
        --dm-border: #2b3a55;
        --dm-accent: #7db3ff;
        --dm-accent-strong: #9ec5ff;
      }
      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
      }
      .site-main {
        flex: 1;
        padding-left: 16px;
        padding-right: 16px;
      }
      .site-gutter {
        padding-left: 16px;
        padding-right: 16px;
      }
      @media (min-width: 768px) {
        .site-main,
        .site-gutter {
          padding-left: 20px;
          padding-right: 20px;
        }
      }
      @media (min-width: 1024px) {
        .site-main,
        .site-gutter {
          padding-left: 24px;
          padding-right: 24px;
        }
      }
      html.dark body {
        background-color: var(--dm-bg);
        color: var(--dm-text);
      }
      html.dark h1,
      html.dark h2,
      html.dark h3,
      html.dark h4,
      html.dark h5,
      html.dark h6 {
        color: var(--dm-text-strong);
      }
      html.dark p,
      html.dark li,
      html.dark span,
      html.dark label,
      html.dark td,
      html.dark th {
        color: var(--dm-text);
      }
      html.dark a {
        color: var(--dm-accent);
      }
      html.dark a:hover {
        color: var(--dm-accent-strong);
      }
      html.dark a.dashboard-hero-btn {
        color: #ffffff !important;
      }
      html.dark a.dashboard-hero-btn.bg-emerald-500 {
        background-color: #10c995 !important;
      }
      html.dark a.dashboard-hero-btn.bg-emerald-500:hover {
        background-color: #20e0ab !important;
      }
      html.dark a.dashboard-hero-btn.bg-indigo-500 {
        background-color: #4a78e8 !important;
      }
      html.dark a.dashboard-hero-btn.bg-indigo-500:hover {
        background-color: #5b89f2 !important;
      }
      html.dark a.dashboard-hero-btn.bg-white\/10 {
        background-color: rgba(125, 179, 255, 0.24) !important;
        border-color: rgba(157, 197, 255, 0.55) !important;
      }
      html.dark a.dashboard-hero-btn.bg-white\/10:hover {
        background-color: rgba(125, 179, 255, 0.34) !important;
      }
      html.dark .bg-white {
        background-color: var(--dm-surface-2) !important;
      }
      html.dark .bg-white\/95 {
        background-color: rgba(11, 18, 32, 0.92) !important;
      }
      html.dark .bg-slate-50 {
        background-color: var(--dm-bg) !important;
      }
      html.dark .bg-slate-100 {
        background-color: var(--dm-surface-3) !important;
      }
      html.dark .bg-slate-900 {
        background-color: var(--dm-surface) !important;
      }
      html.dark .bg-indigo-50,
      html.dark .bg-rose-50,
      html.dark .bg-emerald-100,
      html.dark .bg-emerald-50 {
        background-color: #142033 !important;
      }
      html.dark .text-slate-900 {
        color: var(--dm-text-strong) !important;
      }
      html.dark .text-slate-700,
      html.dark .text-slate-600,
      html.dark .text-slate-500 {
        color: var(--dm-text) !important;
      }
      html.dark .text-slate-400 {
        color: var(--dm-text-muted) !important;
      }
      html.dark .text-gray-900 {
        color: var(--dm-text-strong) !important;
      }
      html.dark .text-gray-500 {
        color: var(--dm-text-muted) !important;
      }
      html.dark .text-indigo-700,
      html.dark .text-indigo-600,
      html.dark .text-indigo-200,
      html.dark .text-indigo-100,
      html.dark .text-cyan-200 {
        color: var(--dm-accent-strong) !important;
      }
      html.dark .text-rose-600 {
        color: #ff9aa7 !important;
      }
      html.dark .text-emerald-700,
      html.dark .text-emerald-600 {
        color: #86efac !important;
      }
      html.dark .text-emerald-800,
      html.dark .text-emerald-900,
      html.dark .text-emerald-950 {
        color: #b8f6d6 !important;
      }
      html.dark .text-yellow-400,
      html.dark .text-amber-500 {
        color: #fcd34d !important;
      }
      html.dark .border-slate-200,
      html.dark .border-slate-300,
      html.dark .border-slate-700 {
        border-color: var(--dm-border) !important;
      }
      html.dark .border-rose-200,
      html.dark .border-emerald-200 {
        border-color: #3b4c68 !important;
      }
      html.dark .border-emerald-300 {
        border-color: #1f8f5e !important;
      }
      html.dark .ring-rose-200 {
        --tw-ring-color: rgba(251, 113, 133, 0.55) !important;
      }
      html.dark input,
      html.dark select,
      html.dark textarea {
        background-color: var(--dm-surface) !important;
        color: var(--dm-text-strong) !important;
        border-color: var(--dm-border) !important;
      }
      html.dark input::placeholder,
      html.dark textarea::placeholder {
        color: var(--dm-text-muted);
      }
      html.dark .hover\:text-indigo-600:hover {
        color: var(--dm-accent-strong) !important;
      }
      html.dark .bg-indigo-600,
      html.dark .bg-indigo-500,
      html.dark .bg-indigo-400 {
        background-color: #2f5eaa !important;
      }
      html.dark .hover\:bg-indigo-700:hover {
        background-color: #3b6bb6 !important;
      }
      html.dark .retailer-reply-box {
        background-color: #103326 !important;
        border-color: #1f8f5e !important;
      }
      html.dark .retailer-reply-label {
        color: #93f4c4 !important;
      }
      html.dark .retailer-reply-text {
        color: #eafff3 !important;
      }
      html.dark .retailer-reply-time {
        color: #b8f6d6 !important;
      }
      html.dark .pending-count-badge {
        background-color: #7a4b07 !important;
        color: #fff3bf !important;
        border: 1px solid #fbbf24 !important;
      }
      .notification-nav-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        line-height: 1;
      }
      .notification-nav-icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
        display: block;
        position: relative;
        top: 1px;
      }
      html.dark .notification-nav-icon {
        filter: invert(1) brightness(1.15);
      }
      .notification-nav-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 20px;
        border-radius: 9999px;
        padding: 0 6px;
        font-size: 11px;
        line-height: 1;
        font-weight: 700;
        background: #dc2626;
        color: #ffffff;
      }
      html.dark .notification-nav-badge {
        background: #ef4444;
        color: #fff7ed;
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
      }
      html.dark .notification-history-status.notification-history-status-replied {
        color: #8dffba !important;
      }
      html.dark .notification-history-status.notification-history-status-pending {
        color: #ffd27a !important;
      }
      html.dark .notification-history-reply-box {
        background-color: #143a2b !important;
        border-color: #1fa06e !important;
      }
      html.dark .notification-history-reply-label {
        color: #afffd4 !important;
      }
      html.dark .notification-history-reply-text {
        color: #effff6 !important;
      }
      html.dark .notification-history-reply-time {
        color: #84f0ba !important;
      }
      html.dark .dm-bright-btn {
        color: #f8fbff !important;
      }
      html.dark .dm-bright-btn.dm-bright-emerald {
        background-color: #0db985 !important;
      }
      html.dark .dm-bright-btn.dm-bright-emerald:hover {
        background-color: #18d39a !important;
      }
      html.dark .dm-bright-btn.dm-bright-indigo {
        background-color: #4675e4 !important;
      }
      html.dark .dm-bright-btn.dm-bright-indigo:hover {
        background-color: #5d89ef !important;
      }
      html.dark .dm-bright-btn.dm-bright-outline {
        color: #dbeafe !important;
        border-color: #7aa2f7 !important;
        background-color: rgba(73, 113, 196, 0.2) !important;
      }
      html.dark .dm-bright-btn.dm-bright-outline:hover {
        background-color: rgba(109, 151, 238, 0.3) !important;
        border-color: #93c5fd !important;
      }
      html.dark .dm-bright-btn.dm-bright-warning {
        color: #ffd27a !important;
        border-color: #f59e0b !important;
        background-color: rgba(123, 70, 0, 0.16) !important;
      }
      html.dark .dm-bright-btn.dm-bright-warning:hover {
        color: #ffe7a8 !important;
        border-color: #fbbf24 !important;
        background-color: rgba(160, 88, 0, 0.26) !important;
      }
      .theme-toggle {
        border: 0;
        background: transparent;
        padding: 0;
      }
      .theme-toggle-track {
        width: 74px;
        height: 38px;
        border-radius: 9999px;
        background: #e5e7eb;
        border: 1px solid #cbd5e1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        position: relative;
        transition: background-color 180ms ease, border-color 180ms ease;
      }
      .theme-toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 30px;
        height: 30px;
        border-radius: 9999px;
        background: #3244aa;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 16px;
        line-height: 1;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.25);
        transition: transform 180ms ease, background-color 180ms ease;
      }
      .theme-toggle-icons {
        width: 100%;
        display: flex;
        justify-content: space-between;
        font-size: 16px;
        line-height: 1;
        color: #6b7280;
      }
      html.dark .theme-toggle {
        background: transparent;
      }
      html.dark .theme-toggle-track {
        background: #111827;
        border-color: #1f2937;
      }
      html.dark .theme-toggle-thumb {
        transform: translateX(36px);
        background: #3244aa;
      }
      html.dark .theme-toggle-icons {
        color: #9ca3af;
      }
    </style>
  </head>
  <body
    class="bg-slate-50 text-slate-900"
    data-authenticated="<%= currentUser ? 'true' : 'false' %>"
    data-user-role="<%= currentUser ? currentUser.role : 'guest' %>"
  >
    <div class="site-shell">
      <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
        <div class="w-full site-gutter">
          <div class="h-16 flex items-center justify-between gap-4">
            <a href="/" class="text-xl font-bold text-indigo-600">ShardaCart</a>
            <form id="searchForm" action="/products/allProducts" method="get" class="hidden md:flex flex-1 max-w-xl">
              <input
                type="text"
                name="q"
                id="searchInput"
                placeholder="Search products"
                class="w-full rounded-l-lg border border-slate-300 px-3 py-2 focus:outline-none focus:border-indigo-500"
              />
              <button class="rounded-r-lg bg-slate-900 text-white px-4 py-2">Search</button>
            </form>
            <nav class="flex items-center gap-3 sm:gap-5 text-sm font-medium">
              <a href="/" class="text-slate-700 hover:text-indigo-600">Home</a>
              <% if (currentUser) { %>
              <% const isRetailer = currentUser.role === "retailer" || currentUser.role === "admin"; %>
              <% const isBuyer = currentUser.role === "buyer"; %>
              <% if (isRetailer) { %>
              <a href="/products/new" class="text-slate-700 hover:text-indigo-600">Add Product</a>
              <a href="/products/allProducts" class="text-slate-700 hover:text-indigo-600">My Products</a>
              <% } %>
              <% if (isBuyer) { %>
              <a href="/products/allProducts" class="text-slate-700 hover:text-indigo-600">Shop</a>
              <a href="/products/cart" class="text-slate-700 hover:text-indigo-600">Cart</a>
              <a href="/products/wishlist" class="text-slate-700 hover:text-indigo-600">
                Wishlist<% if (currentUser.wishlist && currentUser.wishlist.length) { %> (<%= currentUser.wishlist.length %>)<% } %>
              </a>
              <% } %>
              <span class="text-slate-500 hidden sm:inline">Hi, <%= currentUser.name %></span>
              <% if (isRetailer) { %>
              <% const unreadNotificationCount = Number(retailerNotificationUnreadCount || 0); %>
              <div class="relative group py-2 -my-2">
                <a href="/products/notifications" class="notification-nav-link text-slate-700 hover:text-indigo-600" aria-label="Notifications" title="Notifications">
                  <img src="/image.png" alt="Notifications" class="notification-nav-icon" />
                  <span
                    id="retailerNotificationNavBadge"
                    class="notification-nav-badge <%= unreadNotificationCount > 0 ? '' : 'hidden' %>"
                    data-count="<%= unreadNotificationCount %>"
                  ><%= unreadNotificationCount > 9 ? "9+" : unreadNotificationCount %></span>
                </a>
                <div class="invisible opacity-0 translate-y-1 pointer-events-none group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-150 absolute right-0 top-full z-50 w-[340px] max-h-[360px] overflow-auto rounded-xl border border-slate-200 bg-white p-3 shadow-xl">
                  <div class="flex items-center justify-between">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Recent Messages</p>
                    <a href="/products/notifications" class="text-xs text-indigo-600 hover:text-indigo-500 font-semibold">Open all</a>
                  </div>
                  <div id="retailerNotificationPreviewList" class="mt-2 space-y-2">
                    <% if (retailerNotificationPreview && retailerNotificationPreview.length) { %>
                    <% retailerNotificationPreview.forEach(function(item) { %>
                    <a
                      href="<%= item.href %>"
                      class="notification-preview-item block rounded-lg border border-slate-200 px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50/50"
                      data-notification-id="<%= item.id %>"
                    >
                      <p class="text-sm font-semibold text-slate-900"><%= item.productName %></p>
                      <p class="text-xs text-slate-600 mt-0.5"><%= item.buyerName %></p>
                      <p class="text-xs text-slate-500 mt-1 truncate"><%= item.comment %></p>
                    </a>
                    <% }); %>
                    <% } else { %>
                    <p id="retailerPreviewEmpty" class="text-xs text-slate-500">No messages yet.</p>
                    <% } %>
                  </div>
                </div>
              </div>
              <% } %>
              <% if (isBuyer) { %>
              <% const buyerUnreadCount = Number(buyerNotificationUnreadCount || 0); %>
              <div class="relative group py-2 -my-2">
                <a href="/products/my-notifications" class="notification-nav-link text-slate-700 hover:text-indigo-600" aria-label="Notifications" title="Notifications">
                  <img src="/image.png" alt="Notifications" class="notification-nav-icon" />
                  <span
                    id="buyerNotificationNavBadge"
                    class="notification-nav-badge <%= buyerUnreadCount > 0 ? '' : 'hidden' %>"
                    data-count="<%= buyerUnreadCount %>"
                  ><%= buyerUnreadCount > 9 ? "9+" : buyerUnreadCount %></span>
                </a>
                <div class="invisible opacity-0 translate-y-1 pointer-events-none group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-150 absolute right-0 top-full z-50 w-[340px] max-h-[360px] overflow-auto rounded-xl border border-slate-200 bg-white p-3 shadow-xl">
                  <div class="flex items-center justify-between">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Reply Alerts</p>
                    <a href="/products/my-notifications" class="text-xs text-indigo-600 hover:text-indigo-500 font-semibold">Open all</a>
                  </div>
                  <div id="buyerNotificationPreviewList" class="mt-2 space-y-2">
                    <% if (buyerNotificationPreview && buyerNotificationPreview.length) { %>
                    <% buyerNotificationPreview.forEach(function(item) { %>
                    <a
                      href="<%= item.href %>"
                      class="buyer-notification-preview-item block rounded-lg border border-slate-200 px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50/50"
                      data-notification-id="<%= item.id %>"
                    >
                      <p class="text-sm font-semibold text-slate-900"><%= item.productName %></p>
                      <p class="text-xs text-slate-600 mt-0.5">Reply by <%= item.repliedBy || 'Retailer' %></p>
                      <p class="text-xs text-slate-500 mt-1 truncate"><%= item.reply || 'You have a new reply' %></p>
                    </a>
                    <% }); %>
                    <% } else { %>
                    <p id="buyerPreviewEmpty" class="text-xs text-slate-500">No reply alerts yet.</p>
                    <% } %>
                  </div>
                </div>
              </div>
              <% } %>
              <form
                action="/auth/logout"
                method="post"
                class="inline"
                data-confirm-message="Logout now? You may lose unsaved changes."
                data-confirm-cta="Logout"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="text-slate-700 hover:text-indigo-600">Logout</button>
              </form>
              <button
                type="button"
                class="theme-toggle"
                data-theme-toggle
                aria-label="Toggle dark mode"
                title="Toggle dark mode"
              >
                <span class="theme-toggle-track" aria-hidden="true">
                  <span class="theme-toggle-icons">
                    <span>&#9728;</span>
                    <span>&#9790;</span>
                  </span>
                  <span class="theme-toggle-thumb"></span>
                </span>
              </button>
              <% } else { %>
              <a href="/auth/login" class="text-slate-700 hover:text-indigo-600">Login</a>
              <button
                type="button"
                class="text-slate-700 hover:text-indigo-600"
                data-requires-auth="true"
                data-login-url="/auth/login"
                data-permission-message="Please login to save wishlist."
              >
                Wishlist
              </button>
              <a href="/auth/register" class="rounded-md bg-indigo-600 px-3 py-1.5 text-white hover:bg-indigo-700">Register</a>
              <button
                type="button"
                class="theme-toggle"
                data-theme-toggle
                aria-label="Toggle dark mode"
                title="Toggle dark mode"
              >
                <span class="theme-toggle-track" aria-hidden="true">
                  <span class="theme-toggle-icons">
                    <span>&#9728;</span>
                    <span>&#9790;</span>
                  </span>
                  <span class="theme-toggle-thumb"></span>
                </span>
              </button>
              <% } %>
            </nav>
          </div>
        </div>
      </header>
      <script src="/socket.io/socket.io.js"></script>
      <% if (currentUser && (currentUser.role === "retailer" || currentUser.role === "admin")) { %>
      <script>
        (function () {
          const retailerId = "<%= String(currentUser._id || '') %>";
          if (!retailerId || !window.io) return;

          const badge = document.getElementById("retailerNotificationNavBadge");
          const previewList = document.getElementById("retailerNotificationPreviewList");
          const maxPreviewItems = 6;

          const getBadgeCount = () => Number(badge?.getAttribute("data-count") || "0") || 0;
          const setBadgeCount = (value) => {
            if (!badge) return;
            const nextCount = Math.max(0, Number(value) || 0);
            badge.setAttribute("data-count", String(nextCount));
            badge.textContent = nextCount > 9 ? "9+" : String(nextCount);
            badge.classList.toggle("hidden", nextCount <= 0);
          };

          const escapeHtml = (value) =>
            String(value || "")
              .replace(/&/g, "&amp;")
              .replace(/</g, "&lt;")
              .replace(/>/g, "&gt;")
              .replace(/\"/g, "&quot;")
              .replace(/'/g, "&#39;");

          const removePreviewEmpty = () => {
            if (!previewList) return;
            const emptyNode = document.getElementById("retailerPreviewEmpty");
            if (emptyNode) emptyNode.remove();
          };

          const ensurePreviewEmpty = () => {
            if (!previewList) return;
            const hasItems = previewList.querySelector(".notification-preview-item");
            if (hasItems || document.getElementById("retailerPreviewEmpty")) return;
            const emptyText = document.createElement("p");
            emptyText.id = "retailerPreviewEmpty";
            emptyText.className = "text-xs text-slate-500";
            emptyText.textContent = "No messages yet.";
            previewList.appendChild(emptyText);
          };

          const trimPreviewItems = () => {
            if (!previewList) return;
            const items = previewList.querySelectorAll(".notification-preview-item");
            for (let index = maxPreviewItems; index < items.length; index += 1) {
              items[index].remove();
            }
          };

          const upsertPreviewItem = (notification) => {
            if (!previewList || !notification || !notification.id) return;
            const existing = previewList.querySelector(
              '.notification-preview-item[data-notification-id="' + String(notification.id) + '"]'
            );
            if (existing) existing.remove();
            removePreviewEmpty();

            const item = document.createElement("a");
            item.className = "notification-preview-item block rounded-lg border border-slate-200 px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50/50";
            item.setAttribute("data-notification-id", String(notification.id));
            item.href = notification.href || "/products/notifications";
            item.innerHTML = [
              '<p class="text-sm font-semibold text-slate-900">' + escapeHtml(notification.productName || "Product unavailable") + "</p>",
              '<p class="text-xs text-slate-600 mt-0.5">' + escapeHtml(notification.buyerName || "Buyer") + "</p>",
              '<p class="text-xs text-slate-500 mt-1 truncate">' + escapeHtml(notification.comment || "") + "</p>",
            ].join("");

            previewList.insertBefore(item, previewList.firstChild);
            trimPreviewItems();
            ensurePreviewEmpty();
          };

          setBadgeCount(getBadgeCount());

          const socket = window.__appRealtimeSocket || window.io();
          window.__appRealtimeSocket = socket;

          if (!window.__retailerRealtimeSocketJoined) {
            socket.emit("retailer:join", retailerId);
            window.__retailerRealtimeSocketJoined = retailerId;
            window.addEventListener("beforeunload", () => {
              socket.emit("retailer:leave", retailerId);
            });
          }

          if (!window.__retailerRealtimeHandlersAttached) {
            window.__retailerRealtimeHandlersAttached = true;
            socket.on("retailer:notification:new", (payload) => {
              const notification = payload?.notification;
              if (!notification) return;
              setBadgeCount(getBadgeCount() + 1);
              upsertPreviewItem(notification);
              window.dispatchEvent(new CustomEvent("retailer-notification:new", { detail: notification }));
            });

            socket.on("retailer:notification:replied", (payload) => {
              const notification = payload?.notification;
              if (!notification) return;
              setBadgeCount(getBadgeCount() - 1);
              upsertPreviewItem(notification);
              window.dispatchEvent(new CustomEvent("retailer-notification:replied", { detail: notification }));
            });
          }
        })();
      </script>
      <% } %>
      <% if (currentUser && currentUser.role === "buyer") { %>
      <script>
        (function () {
          const buyerId = "<%= String(currentUser._id || '') %>";
          if (!buyerId || !window.io) return;

          const badge = document.getElementById("buyerNotificationNavBadge");
          const previewList = document.getElementById("buyerNotificationPreviewList");
          const maxPreviewItems = 6;

          const getBadgeCount = () => Number(badge?.getAttribute("data-count") || "0") || 0;
          const setBadgeCount = (value) => {
            if (!badge) return;
            const nextCount = Math.max(0, Number(value) || 0);
            badge.setAttribute("data-count", String(nextCount));
            badge.textContent = nextCount > 9 ? "9+" : String(nextCount);
            badge.classList.toggle("hidden", nextCount <= 0);
          };

          const escapeHtml = (value) =>
            String(value || "")
              .replace(/&/g, "&amp;")
              .replace(/</g, "&lt;")
              .replace(/>/g, "&gt;")
              .replace(/\"/g, "&quot;")
              .replace(/'/g, "&#39;");

          const removePreviewEmpty = () => {
            if (!previewList) return;
            const emptyNode = document.getElementById("buyerPreviewEmpty");
            if (emptyNode) emptyNode.remove();
          };

          const ensurePreviewEmpty = () => {
            if (!previewList) return;
            const hasItems = previewList.querySelector(".buyer-notification-preview-item");
            if (hasItems || document.getElementById("buyerPreviewEmpty")) return;
            const emptyText = document.createElement("p");
            emptyText.id = "buyerPreviewEmpty";
            emptyText.className = "text-xs text-slate-500";
            emptyText.textContent = "No reply alerts yet.";
            previewList.appendChild(emptyText);
          };

          const trimPreviewItems = () => {
            if (!previewList) return;
            const items = previewList.querySelectorAll(".buyer-notification-preview-item");
            for (let index = maxPreviewItems; index < items.length; index += 1) {
              items[index].remove();
            }
          };

          const upsertPreviewItem = (notification) => {
            if (!previewList || !notification || !notification.id) return;
            const existing = previewList.querySelector(
              '.buyer-notification-preview-item[data-notification-id="' + String(notification.id) + '"]'
            );
            if (existing) existing.remove();
            removePreviewEmpty();

            const item = document.createElement("a");
            item.className = "buyer-notification-preview-item block rounded-lg border border-slate-200 px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50/50";
            item.setAttribute("data-notification-id", String(notification.id));
            item.href = notification.href || "/products/my-notifications";
            item.innerHTML = [
              '<p class="text-sm font-semibold text-slate-900">' + escapeHtml(notification.productName || "Product unavailable") + "</p>",
              '<p class="text-xs text-slate-600 mt-0.5">Reply by ' + escapeHtml(notification.repliedBy || "Retailer") + "</p>",
              '<p class="text-xs text-slate-500 mt-1 truncate">' + escapeHtml(notification.reply || "You have a new reply") + "</p>",
            ].join("");

            previewList.insertBefore(item, previewList.firstChild);
            trimPreviewItems();
            ensurePreviewEmpty();
          };

          const showBuyerPopup = (notification) => {
            if (!notification || document.hidden) return;
            const message = "New reply on " + (notification.productName || "your product review");
            if (window.AppPopup && typeof window.AppPopup.showToast === "function") {
              window.AppPopup.showToast(message, "success", 3500);
              return;
            }

            const toast = document.createElement("div");
            toast.className = "fixed top-4 right-4 z-[120] rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800 shadow-lg";
            toast.textContent = message;
            document.body.appendChild(toast);
            window.setTimeout(() => toast.remove(), 3200);
          };

          setBadgeCount(getBadgeCount());

          const socket = window.__appRealtimeSocket || window.io();
          window.__appRealtimeSocket = socket;

          if (!window.__buyerRealtimeSocketJoined) {
            socket.emit("buyer:join", buyerId);
            window.__buyerRealtimeSocketJoined = buyerId;
            window.addEventListener("beforeunload", () => {
              socket.emit("buyer:leave", buyerId);
            });
          }

          if (!window.__buyerRealtimeHandlersAttached) {
            window.__buyerRealtimeHandlersAttached = true;
            socket.on("buyer:notification:new", (payload) => {
              const notification = payload?.notification;
              if (!notification) return;
              setBadgeCount(getBadgeCount() + 1);
              upsertPreviewItem(notification);
              showBuyerPopup(notification);
              window.dispatchEvent(new CustomEvent("buyer-notification:new", { detail: notification }));
            });
          }
        })();
      </script>
      <% } %>
