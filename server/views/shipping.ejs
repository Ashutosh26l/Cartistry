<%- include("partials/header", { title: "Shipping Information" }) %>

<section class="min-h-[70vh] px-6 py-10">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Shipping</h1>
    <p class="mt-3 text-slate-600">
      Delivery timelines and charges are shown clearly before checkout.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Standard Delivery</h2>
        <p class="mt-2 text-sm text-slate-600">
          Orders are usually delivered within 3-5 business days.
        </p>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Express Delivery</h2>
        <p class="mt-2 text-sm text-slate-600">
          Eligible locations can receive orders in 1-2 business days.
        </p>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Shipping Charges</h2>
        <p class="mt-2 text-sm text-slate-600">
          Shipping is free on qualifying orders. Otherwise, a small delivery fee applies at checkout.
        </p>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Order Tracking</h2>
        <p class="mt-2 text-sm text-slate-600">
          Track live updates from your orders page after shipment is dispatched.
        </p>
      </article>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
