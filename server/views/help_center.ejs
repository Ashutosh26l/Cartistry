<%- include("partials/header", { title: "Help Center" }) %>

<section class="min-h-[70vh] px-6 py-10">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Help Center</h1>
    <p class="mt-3 text-slate-600">
      Need help with your order, account, or payment? Find quick answers below.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Order Status</h2>
        <p class="mt-2 text-sm text-slate-600">
          Go to your dashboard and open your recent orders to track current delivery updates.
        </p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Payment Support</h2>
        <p class="mt-2 text-sm text-slate-600">
          For failed payments, wait 10 minutes and retry. If amount is debited, it is auto-refunded in 3-5 days.
        </p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Account Help</h2>
        <p class="mt-2 text-sm text-slate-600">
          Use the registered email on login. For role-based access, `@tri.com` users are treated as retailers.
        </p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Still Need Help?</h2>
        <p class="mt-2 text-sm text-slate-600">
          Contact support at <span class="font-medium text-slate-800">support@shardacart.com</span> or call
          <span class="font-medium text-slate-800">+91-00000-00000</span>.
        </p>
      </article>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
