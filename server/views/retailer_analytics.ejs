<%- include("partials/header", { title: "Retailer Analytics" }) %>

<section class="max-w-6xl mx-auto py-10">
  <%- include("partials/flash") %>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Retailer Operations</p>
      <h1 class="text-3xl font-bold text-slate-900 mt-1">Analytics Dashboard</h1>
      <p class="text-slate-500 mt-2">Sales, conversion and pending reply insights.</p>
    </div>
    <form method="GET" action="/retailer/analytics" class="flex items-center gap-2">
      <select name="range" class="rounded-lg border border-slate-300 px-3 py-2">
        <option value="7d" <%= analytics.range === "7d" ? "selected" : "" %>>Last 7 days</option>
        <option value="30d" <%= analytics.range === "30d" ? "selected" : "" %>>Last 30 days</option>
        <option value="90d" <%= analytics.range === "90d" ? "selected" : "" %>>Last 90 days</option>
      </select>
      <button type="submit" class="rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-4 py-2">Apply</button>
    </form>
  </div>

  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4">
    <div class="bg-white border border-slate-200 rounded-xl p-4">
      <p class="text-sm text-slate-500">Sales</p>
      <p class="text-2xl font-bold text-slate-900 mt-1">&#8377; <%= Number(analytics.sales || 0).toFixed(2) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4">
      <p class="text-sm text-slate-500">Orders</p>
      <p class="text-2xl font-bold text-slate-900 mt-1"><%= analytics.orders || 0 %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4">
      <p class="text-sm text-slate-500">AOV</p>
      <p class="text-2xl font-bold text-slate-900 mt-1">&#8377; <%= Number(analytics.aov || 0).toFixed(2) %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4">
      <p class="text-sm text-slate-500">Conversion</p>
      <p class="text-2xl font-bold text-slate-900 mt-1"><%= Number(analytics.conversionRate || 0).toFixed(2) %>%</p>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-4">
      <p class="text-sm text-slate-500">Pending Replies</p>
      <p class="text-2xl font-bold text-slate-900 mt-1"><%= analytics.pendingReplies || 0 %></p>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white border border-slate-200 rounded-2xl p-6">
      <h2 class="text-xl font-bold text-slate-900">Sales Trend</h2>
      <p class="text-sm text-slate-500 mt-1">Daily totals for selected period.</p>
      <div class="mt-4 max-h-[360px] overflow-auto rounded-lg border border-slate-200">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="text-left px-4 py-2">Date</th>
              <th class="text-left px-4 py-2">Orders</th>
              <th class="text-left px-4 py-2">Sales</th>
            </tr>
          </thead>
          <tbody>
            <% if (analytics.trend && analytics.trend.length) { %>
            <% analytics.trend.forEach(function(item) { %>
            <tr class="border-t border-slate-200">
              <td class="px-4 py-2"><%= item.label %></td>
              <td class="px-4 py-2"><%= item.orders %></td>
              <td class="px-4 py-2">&#8377; <%= Number(item.total || 0).toFixed(2) %></td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr>
              <td colspan="3" class="px-4 py-6 text-slate-500">No order trend data yet for this range.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6">
      <h2 class="text-xl font-bold text-slate-900">Top Products</h2>
      <p class="text-sm text-slate-500 mt-1">Ranked by revenue.</p>
      <div class="mt-4 space-y-3">
        <% if (analytics.topProducts && analytics.topProducts.length) { %>
        <% analytics.topProducts.forEach(function(item, index) { %>
        <div class="rounded-lg border border-slate-200 p-3">
          <p class="font-semibold text-slate-900"><%= index + 1 %>. <%= item.productName %></p>
          <p class="text-sm text-slate-600 mt-1">Qty sold: <%= item.quantity %></p>
          <p class="text-sm text-indigo-700 mt-1">Revenue: &#8377; <%= Number(item.revenue || 0).toFixed(2) %></p>
        </div>
        <% }); %>
        <% } else { %>
        <p class="text-slate-500">No top products yet.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <a href="/retailer/bulk/upload" class="rounded-lg border border-slate-300 hover:border-indigo-400 p-4">
      <p class="font-semibold text-slate-900">Bulk Upload</p>
      <p class="text-sm text-slate-500 mt-1">Upload CSV catalog quickly.</p>
    </a>
    <a href="/retailer/bulk/edit" class="rounded-lg border border-slate-300 hover:border-indigo-400 p-4">
      <p class="font-semibold text-slate-900">Bulk Edit</p>
      <p class="text-sm text-slate-500 mt-1">Update many products at once.</p>
    </a>
    <a href="/retailer/notification-preferences" class="rounded-lg border border-slate-300 hover:border-indigo-400 p-4">
      <p class="font-semibold text-slate-900">Notification Preferences</p>
      <p class="text-sm text-slate-500 mt-1">Control in-app and email alerts.</p>
    </a>
  </div>
</section>

<%- include("partials/footer") %>

