<%- include("partials/header", { title: "Retailer Bulk Edit" }) %>

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-10">
  <%- include("partials/flash") %>
  <div class="flex flex-wrap items-end justify-between gap-3 mb-6">
    <div>
      <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Retailer Operations</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mt-1">Bulk Edit Products</h1>
      <p class="text-slate-500 mt-2">Select products and apply one operation at scale.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
    <div class="lg:col-span-2 bg-white border border-slate-200 rounded-2xl p-4 sm:p-6">
      <form method="POST" action="/retailer/bulk/edit/preview" id="bulkEditPreviewForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700">Operation</label>
            <select name="operation" class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2">
              <option value="price_percent" <%= operation === "price_percent" ? "selected" : "" %>>Price % (+/-)</option>
              <option value="price_fixed" <%= operation === "price_fixed" ? "selected" : "" %>>Price fixed (+/-)</option>
              <option value="set_category" <%= operation === "set_category" ? "selected" : "" %>>Set category</option>
              <option value="set_brand" <%= operation === "set_brand" ? "selected" : "" %>>Set brand</option>
              <option value="set_availability" <%= operation === "set_availability" ? "selected" : "" %>>Set availability</option>
              <option value="set_quantity" <%= operation === "set_quantity" ? "selected" : "" %>>Set quantity</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700">Value</label>
            <input type="text" name="operationValue" value="<%= operationValue || "" %>" class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="e.g. 10, -50, Electronics, true, 25" />
          </div>
        </div>

        <label class="block text-sm font-medium text-slate-700 mt-5">Selected Product IDs</label>
        <textarea id="selectedIdsField" name="selectedIds" rows="3" class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-xs" placeholder="Selected IDs will appear here..."><%= (selectedIds || []).join(",") %></textarea>

        <div class="mt-4">
          <button type="submit" class="w-full sm:w-auto rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-5 py-2">Preview Changes</button>
        </div>
      </form>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-6">
      <h2 class="text-lg font-bold text-slate-900">Quick Tips</h2>
      <ul class="mt-3 text-sm text-slate-600 space-y-2">
        <li>Price % accepts negative and positive values.</li>
        <li>Availability accepts `true` or `false`.</li>
        <li>Preview before apply to avoid accidental edits.</li>
      </ul>
    </div>
  </div>

  <div class="mt-8 bg-white border border-slate-200 rounded-2xl p-4 sm:p-6">
    <h2 class="text-lg sm:text-xl font-bold text-slate-900">Product Selection</h2>
    <div class="hidden md:block mt-4 max-h-[380px] overflow-auto rounded-lg border border-slate-200">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="text-left px-4 py-2">Select</th>
            <th class="text-left px-4 py-2">Name</th>
            <th class="text-left px-4 py-2">Brand</th>
            <th class="text-left px-4 py-2">Price</th>
            <th class="text-left px-4 py-2">Qty</th>
          </tr>
        </thead>
        <tbody>
          <% if (products && products.length) { %>
          <% products.forEach(function(product) { %>
          <tr class="border-t border-slate-200">
            <td class="px-4 py-2">
              <input type="checkbox" class="bulk-product-checkbox" value="<%= product._id %>" <%= selectedIds && selectedIds.includes(String(product._id)) ? "checked" : "" %> />
            </td>
            <td class="px-4 py-2"><%= product.name %></td>
            <td class="px-4 py-2"><%= product.brand || "-" %></td>
            <td class="px-4 py-2">&#8377; <%= product.price %></td>
            <td class="px-4 py-2"><%= product.quantity %></td>
          </tr>
          <% }); %>
          <% } else { %>
          <tr>
            <td colspan="5" class="px-4 py-6 text-slate-500">No products available.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="md:hidden mt-4 space-y-3">
      <% if (products && products.length) { %>
      <% products.forEach(function(product) { %>
      <label class="block rounded-xl border border-slate-200 p-3 bg-white">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="font-semibold text-slate-900 break-words"><%= product.name %></p>
            <p class="text-sm text-slate-500 mt-1">Brand: <%= product.brand || "-" %></p>
            <p class="text-sm text-slate-500">Price: &#8377; <%= product.price %></p>
            <p class="text-sm text-slate-500">Qty: <%= product.quantity %></p>
          </div>
          <input type="checkbox" class="bulk-product-checkbox h-5 w-5 shrink-0 mt-1" value="<%= product._id %>" <%= selectedIds && selectedIds.includes(String(product._id)) ? "checked" : "" %> />
        </div>
      </label>
      <% }); %>
      <% } else { %>
      <div class="rounded-xl border border-slate-200 p-4 text-sm text-slate-500">No products available.</div>
      <% } %>
    </div>
  </div>

  <% if (previewRows && previewRows.length) { %>
  <div class="mt-8 bg-white border border-slate-200 rounded-2xl p-4 sm:p-6">
    <h2 class="text-lg sm:text-xl font-bold text-slate-900">Preview Result</h2>
    <div class="hidden md:block mt-4 max-h-[360px] overflow-auto rounded-lg border border-slate-200">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="text-left px-4 py-2">Product</th>
            <th class="text-left px-4 py-2">Before</th>
            <th class="text-left px-4 py-2">After</th>
          </tr>
        </thead>
        <tbody>
          <% previewRows.forEach(function(item) { %>
          <tr class="border-t border-slate-200">
            <td class="px-4 py-2"><%= item.product.name %></td>
            <td class="px-4 py-2 text-xs">
              Price: <%= item.before.price %>, Qty: <%= item.before.quantity %>, Category: <%= item.before.category || "-" %>, Brand: <%= item.before.brand || "-" %>
            </td>
            <td class="px-4 py-2 text-xs">
              Price: <%= item.after.price %>, Qty: <%= item.after.quantity %>, Category: <%= item.after.category || "-" %>, Brand: <%= item.after.brand || "-" %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="md:hidden mt-4 space-y-3">
      <% previewRows.forEach(function(item) { %>
      <div class="rounded-xl border border-slate-200 p-3">
        <p class="font-semibold text-slate-900"><%= item.product.name %></p>
        <div class="mt-2 text-xs text-slate-600">
          <p class="font-medium text-slate-800">Before</p>
          <p>Price: <%= item.before.price %>, Qty: <%= item.before.quantity %>, Category: <%= item.before.category || "-" %>, Brand: <%= item.before.brand || "-" %></p>
        </div>
        <div class="mt-2 text-xs text-slate-600">
          <p class="font-medium text-slate-800">After</p>
          <p>Price: <%= item.after.price %>, Qty: <%= item.after.quantity %>, Category: <%= item.after.category || "-" %>, Brand: <%= item.after.brand || "-" %></p>
        </div>
      </div>
      <% }); %>
    </div>

    <form method="POST" action="/retailer/bulk/edit/apply" class="mt-5">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="operation" value="<%= operation %>" />
      <input type="hidden" name="operationValue" value="<%= operationValue %>" />
      <input type="hidden" name="selectedIds" value="<%= (selectedIds || []).join(",") %>" />
      <button type="submit" class="w-full sm:w-auto rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-5 py-2">Apply Changes</button>
    </form>
  </div>
  <% } %>
</section>

<script>
  (function () {
    const field = document.getElementById("selectedIdsField");
    const checkboxes = Array.from(document.querySelectorAll(".bulk-product-checkbox"));
    if (!field || !checkboxes.length) return;
    const syncLinkedCheckboxes = (source) => {
      checkboxes.forEach((box) => {
        if (box !== source && box.value === source.value) {
          box.checked = source.checked;
        }
      });
    };
    const sync = () => {
      const selected = new Set();
      checkboxes.forEach((box) => {
        if (box.checked) selected.add(box.value);
      });
      field.value = Array.from(selected).join(",");
    };
    checkboxes.forEach((box) =>
      box.addEventListener("change", () => {
        syncLinkedCheckboxes(box);
        sync();
      })
    );
    sync();
  })();
</script>

<%- include("partials/footer") %>
