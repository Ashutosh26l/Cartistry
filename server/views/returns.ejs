<%- include("partials/header", { title: "Returns Policy" }) %>

<section class="min-h-[70vh] px-6 py-10">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Returns</h1>
    <p class="mt-3 text-slate-600">
      We keep returns simple and transparent for all customers.
    </p>

    <div class="mt-8 space-y-4">
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Return Window</h2>
        <p class="mt-2 text-sm text-slate-600">
          Most items can be returned within 7 days of delivery if unused and in original packaging.
        </p>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">How to Return</h2>
        <p class="mt-2 text-sm text-slate-600">
          Open your order details, select the item, and choose a return reason. Pickup is scheduled automatically.
        </p>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-lg font-semibold text-slate-900">Refund Timeline</h2>
        <p class="mt-2 text-sm text-slate-600">
          Refunds are initiated after quality check and usually complete within 3-7 working days.
        </p>
      </article>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
